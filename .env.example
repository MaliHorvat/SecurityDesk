# ==================================================
# APPLICATION
# ==================================================
NODE_ENV="development"
APP_NAME="SecurityDesk"
APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="SecurityDesk"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Production example:
# APP_URL="https://securitydesk.visionone.si"
# NEXT_PUBLIC_APP_URL="https://securitydesk.visionone.si"
# BETTER_AUTH_URL="https://securitydesk.visionone.si"
# AUTH_TRUSTED_ORIGINS="https://securitydesk.visionone.si"
APP_TIMEZONE="Europe/Ljubljana"
DEFAULT_LOCALE="sl"

# ==================================================
# DATABASE
# mysql | postgresql
# ==================================================
DB_PROVIDER="mysql"
DB_HOST="localhost"
DB_PORT="3306"
DB_NAME="securitydesk"
DB_USER="securitydesk_user"
DB_PASSWORD="CHANGE_ME"
DB_SSL="false"
# Optional. Setup script generates this automatically.
DATABASE_URL=""
# Optional direct/non-pooled connection for migrations.
DIRECT_DATABASE_URL=""

# ==================================================
# AUTHENTICATION
# Generate secure values with: pnpm setup
# ==================================================
AUTH_SECRET=""
ENCRYPTION_KEY=""
CRON_SECRET=""
AGENT_SIGNING_SECRET=""

# ==================================================
# EMAIL
# console | smtp
# ==================================================
MAIL_DRIVER="console"
MAIL_FROM_NAME="SecurityDesk"
MAIL_FROM_ADDRESS="noreply@example.com"
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASSWORD=""

# ==================================================
# FILE STORAGE
# local | database | s3 | vercel_blob
# ==================================================
STORAGE_DRIVER="local"
MAX_UPLOAD_SIZE_MB="10"
S3_ENDPOINT=""
S3_REGION=""
S3_BUCKET=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_FORCE_PATH_STYLE="false"
BLOB_READ_WRITE_TOKEN=""

# ==================================================
# AI
# disabled | openai | anthropic | google | ollama
# ==================================================
AI_PROVIDER="disabled"
AI_MODEL=""
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
GOOGLE_GENERATIVE_AI_API_KEY=""
OLLAMA_BASE_URL="http://localhost:11434"

# ==================================================
# MONITORING AGENT
# ==================================================
AGENT_API_URL="http://localhost:3000/api/agent"
AGENT_ID=""
AGENT_TOKEN=""
AGENT_POLL_INTERVAL_SECONDS="60"
AGENT_HEARTBEAT_INTERVAL_SECONDS="30"

# ==================================================
# DESKTOP APP API
# Bearer tokens (desktop_api_token) reuse AGENT_SIGNING_SECRET (falls back to
# AUTH_SECRET) to sign short-lived download links. Both are optional.
# ==================================================
DESKTOP_API_TOKEN_TTL_DAYS="90"
DESKTOP_DOWNLOAD_TOKEN_TTL_MINUTES="10"

# ==================================================
# BILLING - OPTIONAL
# ==================================================
BILLING_PROVIDER="disabled"
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# ==================================================
# OBSERVABILITY - OPTIONAL
# ==================================================
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
LOG_LEVEL="info"
