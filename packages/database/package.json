{
  "name": "@securitydesk/database",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema/index.ts",
    "./client": "./src/client.ts"
  },
  "scripts": {
    "generate": "node ./scripts/generate.mjs",
    "migrate": "node ./scripts/migrate.mjs",
    "seed": "tsx ./src/seed.ts",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@securitydesk/config": "workspace:*",
    "@securitydesk/shared": "workspace:*",
    "drizzle-orm": "^0.38.3",
    "mysql2": "^3.12.0",
    "postgres": "^3.4.5"
  },
  "devDependencies": {
    "@types/node": "^20",
    "dotenv": "^16.4.7",
    "drizzle-kit": "^0.30.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
