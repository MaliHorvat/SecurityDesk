{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SecurityDesk",
  "version": "1.0.0",
  "identifier": "si.visionone.securitydesk",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "SecurityDesk",
        "width": 1440,
        "height": 900,
        "minWidth": 1100,
        "minHeight": 700,
        "center": true,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/[email protected]",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "languages": [
          "English",
          "Slovenian"
        ]
      }
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "dialog": true,
      "endpoints": [
        "https://placeholder/api/desktop/updates/{{target}}/{{arch}}/{{current_version}}"
      ],
      "pubkey": "REPLACE_WITH_TAURI_SIGNER_PUBLIC_KEY"
    },
    "deep-link": {
      "desktop": {
        "schemes": [
          "securitydesk"
        ]
      }
    }
  }
}
